FLASK_SECRET_KEY=cambia-esto-por-una-clave-segura-larga
FLASK_DEBUG=true
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=hogarfix_db

# SMTP correo (activar para enviar emails)
MAIL_ENABLED=true
MAIL_BACKEND=smtp
MAIL_FROM_NAME=HogarFix
MAIL_LOGO_URL=

# OAuth social login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/auth/google/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/auth/microsoft/callback
SESSION_COOKIE_SECURE=false
PREFERRED_URL_SCHEME=http

# Admin (codigos de acceso para crear cuentas admin)
ADMIN_LOGIN_CODE=codigo-secreto-admin
ADMIN_REGISTER_CODE=codigo-secreto-registro

# Google Maps
GOOGLE_MAPS_API_KEY=

# Chatbot Fixi (IA con Groq)
GROQ_API_KEY=

# URLs publicas (para links en emails)
MAIL_PUBLIC_BASE_URL=http://localhost:5000



# Opcion 2: Mailtrap SMTP
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=TU_MAILTRAP_USERNAME
MAIL_PASSWORD=TU_MAILTRAP_PASSWORD
MAIL_FROM=no-reply@hogarfix.co

